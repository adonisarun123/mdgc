# Postgres connection string (Supabase or any Postgres in production)
DATABASE_URL=postgres://user:password@localhost:5432/mdgc

# Long random string used to encrypt Payload sessions
PAYLOAD_SECRET=change-me

# Canonical site URL (used for metadata, sitemap and robots)
NEXT_PUBLIC_SITE_URL=https://www.mdgc.golf

# --- Transactional email (REQUIRED before launch) -------------------------
# Without these, enquiry notifications are silently skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=noreply@mdgc.golf
SMTP_FROM_NAME=Mercara Downs Golf Club
# Staff inbox that receives new-enquiry notifications
ENQUIRY_NOTIFY_EMAIL=

# --- Object storage for uploads (REQUIRED for Vercel/serverless) ----------
# Works with Supabase Storage, Cloudflare R2 or AWS S3.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
